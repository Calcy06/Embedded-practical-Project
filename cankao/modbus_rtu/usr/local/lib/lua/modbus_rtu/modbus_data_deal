-- 建大仁科 荧光法溶解氧变送器 RS-LDO-NO1-2-20
function JDRK_LDO(params)
	local cjson = require "cjson"


	-- 溶解氧饱和度 （合并两个4字节十六进制数）
	local DOS = (params[1] * 2^16) + params[2] 
	-- 溶解氧浓度   （合并两个4字节十六进制数）
	local DOC = (params[3] * 2^16) + params[4] 
	-- 温度  	    （合并两个4字节十六进制数）
	local TEM = (params[5] * 2^16) + params[6] 

	DOS  = string.format("%.3f", iee754_hexToFloat(DOS))
	-- print("dos",DOS)
	DOC = string.format("%.3f", iee754_hexToFloat(DOC))
	-- print("doc",DOC)
	TEM = string.format("%.3f", iee754_hexToFloat(TEM))
	-- print("temp",TEM)

	local data_tojson = {Dos=DOS,Doc=DOC,Tem=TEM}
	local jsondata = cjson.encode(data_tojson)

     return jsondata
end

