--iee754 lua计算方法
function iee754_hexToFloat(hexNums)
    local sign = math.modf(hexNums/(2^31))
    local exponent = math.modf(hexNums%(2^31)/(2^23))-127
    local mantissa = hexNums%(2^23)
    for i=1,23 do mantissa=mantissa/2 end
    return (-1)^sign * (1+mantissa) * 2^exponent
end

-- 识别十六进制数
function u16_int16(u16_num1)
	if (u16_num1 >= 32768) then
	   result = u16_num1 - 65536
	else
	   result = u16_num1
	end
 
	return result
 end

