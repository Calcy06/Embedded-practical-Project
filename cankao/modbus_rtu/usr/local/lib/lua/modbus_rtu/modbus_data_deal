--汇控485继电器模块
function HK_RALYCtl(params)
	local cjson = require "cjson"
	local bits  = {}

	-- for i = 1, #params do
	-- 	print("索引", i, "值", params[i])
	-- end
	bits[1] = params[1] % 256
	bits[2] = math.floor(params[1] / 256)
	bits[3] = params[2] % 256
	bits[4] = math.floor(params[2] / 256)
	bits[5] = params[3] % 256
	bits[6] = math.floor(params[3] / 256)
	bits[7] = params[4] % 256
	bits[8] = math.floor(params[4] / 256)

	local com_data = {}
	for idx  = 1 ,#bits ,1 do
		com_data["COM-" .. idx] = bits[idx]  -- 值按 1,2,3,... 递增
	end

	local jsondata = cjson.encode(com_data)

	return jsondata
end

